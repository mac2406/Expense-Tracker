datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenses      Expense[]
  incomes       Income[]
  budgets       Budget[]
  savingsGoals  SavingsGoal[]
  notifications Notification[]
}

model Expense {
  id               String   @id @default(uuid())
  userId           String
  amount           Float
  category         String   // e.g. Housing, Groceries, Transit, Phone, Entertainment, Academic, Miscellaneous
  paymentMethod    String   // e.g. Credit Card, Debit Card, Cash, Interac
  date             DateTime
  notes            String?
  isRecurring      Boolean  @default(false)
  recurrencePeriod String?  // e.g. Daily, Weekly, Monthly, Yearly
  receiptUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Income {
  id               String   @id @default(uuid())
  userId           String
  amount           Float
  category         String   // e.g. Part-time Job, Allowance, Scholarship, Cashback, Refund, Other
  source           String
  date             DateTime
  notes            String?
  isRecurring      Boolean  @default(false)
  recurrencePeriod String?  // e.g. Weekly, Bi-weekly, Monthly
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  limitAmount Float
  category    String   // Category-specific budget or "All" for overall monthly limit
  period      String   @default("Monthly") // e.g. Monthly, Weekly
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsGoal {
  id            String   @id @default(uuid())
  userId        String
  name          String   // e.g. Emergency Fund, Laptop, Winter Clothes, Summer Trip
  targetAmount  Float
  currentAmount Float    @default(0.0)
  targetDate    DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // e.g. BUDGET_WARNING, SAVINGS_MILESTONE, RECURRING_REMINDER, SYSTEM
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
